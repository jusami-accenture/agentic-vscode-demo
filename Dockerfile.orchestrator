# Dockerfile for Agent Orchestrator
# Coordinates multi-agent workflows and task decomposition
FROM python:3.12-slim

LABEL service="orchestrator"
LABEL description="Main orchestrator for agentic workflows"

# Security: Create non-root user
RUN groupadd -r agentuser && useradd -r -g agentuser -u 1000 agentuser

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy requirements and install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY agent/ ./agent/
COPY observability/ ./observability/

# Set ownership
RUN chown -R agentuser:agentuser /app

# Security: Drop privileges
USER agentuser

# Environment variables
ENV PYTHONUNBUFFERED=1
ENV MCP_SERVER_URL=http://mcp-server:3000
ENV INFERENCE_SERVER_URL=http://inference-server:8080

EXPOSE 8001

# Healthcheck
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8001/health || exit 1

# Run orchestrator as API server
CMD ["python", "-m", "uvicorn", "agent.orchestrator:app", "--host", "0.0.0.0", "--port", "8001"]
