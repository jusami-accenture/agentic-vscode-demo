# Dockerfile for MCP Server
# Model Context Protocol server providing tools and resources
FROM python:3.12-slim

LABEL service="mcp-server"
LABEL description="MCP server for tool execution and resource access"

# Security: Create non-root user
RUN groupadd -r mcpuser && useradd -r -g mcpuser -u 1001 mcpuser

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy requirements and install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY mcp-server/ ./mcp-server/
COPY observability/ ./observability/

# Set ownership
RUN chown -R mcpuser:mcpuser /app

# Security: Drop privileges
USER mcpuser

# Environment variables
ENV PYTHONUNBUFFERED=1
ENV MCP_PORT=3000

EXPOSE 3000

# Healthcheck
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:3000/health || exit 1

# Run MCP server
CMD ["python", "-m", "uvicorn", "mcp-server.server:app", "--host", "0.0.0.0", "--port", "3000"]
